# 2. ML MATCH-SCORE – Balkendiagramm aller Rezepte
# ══════════════════════════════════════════════════════════

def show_match_scores(recipes_data):
    """
    Balkendiagramm: ML Match-Score für jedes gefundene Rezept.
    Farb-Kodierung: dunkelgrün ≥ 70%, hellgrün ≥ 40%, blass < 40%.

    Args:
        recipes_data: Liste von Dicts ODER DataFrame.

        Erwartetes Dict-Format (Liste):
        [
            {"title": "Spaghetti ...", "ml_score": 87.3},
            {"title": "Tomatensuppe", "ml_score": 54.1},
            ...
        ]

        Erwartetes DataFrame-Format:
        Spalten: ["title", "ml_score"]   (weitere Spalten werden ignoriert)
    """

    # ── Normalisieren ────────────────────────────────────
    if isinstance(recipes_data, pd.DataFrame):
        df = recipes_data[["title", "ml_score"]].copy()
    else:
        df = pd.DataFrame(recipes_data)[["title", "ml_score"]]

    if df.empty:
        st.warning("Keine Rezeptdaten für den Match-Score vorhanden.")
        return

    # Titel kürzen für die X-Achse
    df["short_title"] = df["title"].apply(
        lambda t: t[:22] + "…" if len(t) > 22 else t
    )
    df = df.sort_values("ml_score", ascending=False)

    # Farben je Score-Bereich
    df["color"] = df["ml_score"].apply(
        lambda s: "#2D4A22" if s >= 70 else ("#7CB342" if s >= 40 else "#AED581")
    )

    fig = go.Figure(go.Bar(
        x=df["short_title"],
        y=df["ml_score"],
        marker_color=df["color"].tolist(),
        text=[f"{s:.0f}%" for s in df["ml_score"]],
        textposition="outside",
        customdata=df["title"],
        hovertemplate="<b>%{customdata}</b><br>Match-Score: %{y:.1f}%<extra></extra>",
    ))

    # Referenzlinie bei 70% (gute Übereinstimmung)
    fig.add_hline(
        y=70, line_dash="dot", line_color="#C62828",
        annotation_text="Guter Match (70%)",
        annotation_position="top right",
        annotation_font_color="#C62828",
    )

    fig.update_layout(
        title=dict(text="🤖 ML Match-Score je Rezept", font=dict(size=17)),
        yaxis=dict(range=[0, 115], title="Match-Score (%)", gridcolor="#EEEEEE"),
        xaxis=dict(tickangle=-30, tickfont=dict(size=11)),
        margin=dict(t=70, b=90, l=50, r=20),
        height=380,
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(0,0,0,0)",
    )
    st.plotly_chart(fig, use_container_width=True)


# ══════════════════════════════════════════════════════════
# 3. ZUTATEN-ABDECKUNG – Stacked Bar (vorhanden vs. fehlend)
# ══════════════════════════════════════════════════════════

def show_ingredient_coverage(recipes_data):
    """
    Stacked Balkendiagramm: Zeigt pro Rezept wie viele Zutaten
    der Nutzer bereits besitzt vs. noch kaufen müsste.

    Args:
        recipes_data: Liste von Dicts ODER DataFrame.

        Erwartetes Dict-Format (Liste):
        [
            {
                "title": "Spaghetti ...",
                "usedIngredientCount":   4,   # Zutaten die der Nutzer hat
                "missedIngredientCount": 2,   # Zutaten die noch fehlen
            },
            ...
        ]

        Erwartetes DataFrame-Format:
        Spalten: ["title", "usedIngredientCount", "missedIngredientCount"]
    """

    # ── Normalisieren ────────────────────────────────────
    needed_cols = ["title", "usedIngredientCount", "missedIngredientCount"]
    if isinstance(recipes_data, pd.DataFrame):
        df = recipes_data[needed_cols].copy()
    else:
        df = pd.DataFrame(recipes_data)[needed_cols]

    if df.empty:
        st.warning("Keine Rezeptdaten für die Zutaten-Abdeckung vorhanden.")
        return

    df["short_title"] = df["title"].apply(
        lambda t: t[:22] + "…" if len(t) > 22 else t
    )
    # Abdeckungs-Prozentsatz berechnen (für Tooltip)
    total = df["usedIngredientCount"] + df["missedIngredientCount"]
    df["coverage_pct"] = (df["usedIngredientCount"] / total * 100).round(1)

    fig = go.Figure()

    # Balken 1: Vorhandene Zutaten (grün)
    fig.add_trace(go.Bar(
        name="✅ Du hast diese Zutaten",
        x=df["short_title"],
        y=df["usedIngredientCount"],
        marker_color="#2D4A22",
        customdata=df[["title", "coverage_pct"]],
        hovertemplate=(
            "<b>%{customdata[0]}</b><br>"
            "Vorhanden: %{y} Zutaten<br>"
            "Abdeckung: %{customdata[1]:.0f}%<extra></extra>"
        ),
    ))

    # Balken 2: Fehlende Zutaten (orange)
    fig.add_trace(go.Bar(
        name="🛒 Diese fehlen noch",
        x=df["short_title"],
        y=df["missedIngredientCount"],
        marker_color="#FFCC80",
        customdata=df["title"],
        hovertemplate=(
            "<b>%{customdata}</b><br>"
            "Fehlend: %{y} Zutaten<extra></extra>"
        ),
    ))

    fig.update_layout(
        barmode="stack",
        title=dict(text="🧺 Zutaten-Abdeckung pro Rezept", font=dict(size=17)),
        legend=dict(orientation="h", yanchor="bottom", y=1.02, xanchor="right", x=1),
        xaxis=dict(tickangle=-30, tickfont=dict(size=11)),
        yaxis=dict(title="Anzahl Zutaten", gridcolor="#EEEEEE", dtick=1),
        margin=dict(t=90, b=90, l=50, r=20),
        height=380,
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(0,0,0,0)",
    )
    st.plotly_chart(fig, use_container_width=True)


